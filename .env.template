# ============================================================================
# SHAKTI & TANTRA Production Environment Configuration Template
# ============================================================================

# Database Configuration (SQLite)
DB_PATH=data/context.db
NONCE_DB_PATH=data/nonce_store.db

# Authentication Settings
# Set AUTH_ENABLED to 'true' to enforce API-key security across all microservices
AUTH_ENABLED=true
# Secret static API key used for service-to-service calls and client request auth
AUTH_API_KEY=prod_shakti_tantra_secret_key_2026
# HS256 JWT signing secret key
AUTH_SECRET_KEY=prod_shakti_tantra_secret_key_2026

# Observability and Performance Configuration
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# Rate Limiting Configuration
# Limits request rates to protect against service floods
RATE_LIMIT_IP_PER_MIN=60
RATE_LIMIT_USER_PER_MIN=30

# Python Path Setup
PYTHONPATH=.:./src:./creator-core/Core-Integrator-Sprint-1.1

# Service URL Overrides (Default local ports)
PROMPT_RUNNER_URL=http://127.0.0.1:8003
CREATOR_CORE_URL=http://127.0.0.1:8000
BHIV_CORE_URL=http://127.0.0.1:8001
BUCKET_URL=http://127.0.0.1:8005
CET_URL=http://127.0.0.1:8006
SARATHI_URL=http://127.0.0.1:8007
GATE_URL=http://127.0.0.1:8008

# TTV/TTG Node.js Microservice Settings
