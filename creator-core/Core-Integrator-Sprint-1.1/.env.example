# Core Integrator Configuration
# Copy this file to .env and update the values for your deployment

# API Configuration
PORT=8000
HOST=0.0.0.0

# Database Configuration
DB_PATH=data/context.db

# Groq API Key for LLM Integration
GROQ_API_KEY=your_groq_api_key_here

# External Service Integration
# These URLs configure integration with other BHIV services

# Prompt Runner Service - Converts prompts to instructions
PROMPT_RUNNER_URL=http://localhost:8003

# BHIV Core Service - Executes blueprints
BHIV_CORE_URL=http://localhost:8001

# Bucket Service - Stores artifacts
BUCKET_URL=http://localhost:8005

# Integration Bridge - Orchestrates all services
INTEGRATION_BRIDGE_URL=http://localhost:8004

# Enable forwarding to BHIV Core (true/false)
# When enabled, generated blueprints are automatically forwarded to BHIV Core for execution
ENABLE_BHIV_FORWARD=false

# Logging Configuration
LOG_LEVEL=INFO
