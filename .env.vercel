# Vercel Environment Configuration
# Copy these to Vercel Dashboard Settings → Environment Variables

# API Configuration
VERCEL_ENV=production
VERCEL_REGION=auto

# LLM Integration
GROQ_API_KEY=your_groq_api_key_here

# Service URLs (Vercel will auto-populate with $VERCEL_URL)
# These point to the same domain, different API routes
PROMPT_RUNNER_URL=https://$VERCEL_URL/api/prompt-runner
CREATOR_CORE_URL=https://$VERCEL_URL/api/creator-core
BHIV_CORE_URL=https://$VERCEL_URL/api/bhiv-core
BUCKET_URL=https://$VERCEL_URL/api/bucket
INTEGRATION_BRIDGE_URL=https://$VERCEL_URL/api/integration-bridge

# Database Configuration (MongoDB Atlas)
USE_MONGODB=true
MONGODB_CONNECTION_STRING=mongodb+srv://user:password@cluster.mongodb.net/bhiv_production?retryWrites=true&w=majority
MONGODB_DATABASE_NAME=bhiv_production

# Storage Configuration (AWS S3)
USE_EXTERNAL_STORAGE=true
AWS_S3_BUCKET=your-bhiv-bucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Feature Flags
ENABLE_BHIV_FORWARD=true
ENABLE_REMOTE_EXECUTION=true
ENABLE_TELEMETRY=true

# Logging
LOG_LEVEL=INFO
