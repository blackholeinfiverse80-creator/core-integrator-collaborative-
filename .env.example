# ============================================================
# .env.example — Copy to .env and fill in real values
# NEVER commit a .env file with real secrets
# ============================================================

# --- Authentication (REQUIRED in production) ---
AUTH_ENABLED=true
AUTH_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
AUTH_API_KEY=change-me-to-a-strong-api-key

# --- Database ---
DB_PATH=data/context.db
USE_MONGODB=false
MONGODB_CONNECTION_STRING=mongodb://user:password@localhost:27017
MONGODB_DATABASE_NAME=core_integrator

# --- Noopur integration ---
INTEGRATOR_USE_NOOPUR=false
NOOPUR_BASE_URL=http://localhost:5001
NOOPUR_API_KEY=

# --- Service URLs ---
PROMPT_RUNNER_URL=http://127.0.0.1:8003
CREATOR_CORE_URL=http://127.0.0.1:8000
BHIV_CORE_URL=http://127.0.0.1:8001
INTEGRATION_BRIDGE_URL=http://127.0.0.1:8004
BHIV_BUCKET_URL=http://127.0.0.1:8005

# --- Timeouts ---
REQUEST_TIMEOUT=30
PIPELINE_TIMEOUT=60
VIDEO_SERVICE_TIMEOUT=300

# --- Logging ---
LOG_LEVEL=INFO

# --- Feature flags ---
SSPL_ENABLED=false
DISABLE_VIDEO_SERVICE=true
