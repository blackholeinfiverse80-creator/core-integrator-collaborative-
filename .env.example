# BHIV Integration Environment Variables
# Copy this file to .env and update values as needed

# Component URLs
PROMPT_RUNNER_URL=http://127.0.0.1:8003
CREATOR_CORE_URL=http://127.0.0.1:8000
BHIV_CORE_URL=http://127.0.0.1:8002
INTEGRATION_BRIDGE_URL=http://127.0.0.1:8004
BHIV_BUCKET_URL=http://127.0.0.1:8005
SIMPLE_ORCHESTRATOR_URL=http://127.0.0.1:8006

# Timeouts (seconds)
REQUEST_TIMEOUT=30
PIPELINE_TIMEOUT=60
COMPONENT_STARTUP_TIMEOUT=10

# Database Configuration
DB_PATH=./data/bhiv_core.db
INTEGRATOR_USE_NOOPUR=false
USE_MONGODB=false
MONGODB_CONNECTION_STRING=mongodb://localhost:27017
MONGODB_DATABASE_NAME=bhiv_integration

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/bhiv_integration.log

# Bucket Storage
BUCKET_STORAGE_PATH=./data/bucket_storage
MAX_ARTIFACT_SIZE_MB=100
ARTIFACT_RETENTION_DAYS=30

# Security
API_KEY_REQUIRED=false
API_KEY=your_api_key_here

# Development
DEBUG_MODE=false
ENABLE_TELEMETRY=true
HEALTH_CHECK_INTERVAL=30