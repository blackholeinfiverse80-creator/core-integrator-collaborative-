FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir fastapi uvicorn[standard]

COPY mock_creatorcore.py .

EXPOSE 5002

HEALTHCHECK --interval=15s --timeout=5s --start-period=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:5002/system/health')"

CMD ["uvicorn", "mock_creatorcore:app", "--host", "0.0.0.0", "--port", "5002"]
